# Port du serveur (défaut: 3000)
PORT=3000

# Host d'écoute (défaut: 0.0.0.0)
HOST=0.0.0.0

# Environnement : development | production
NODE_ENV=production

# URL du site (pour les QR codes et liens)
SITE_URL=https://al-asmaa.app

# Origines autorisées pour CORS (séparées par des virgules)
# IMPORTANT : en production, ne PAS laisser vide (sinon wildcard *)
ALLOWED_ORIGINS=https://al-asmaa.app

# Token pour la revue éditoriale (encyclopédie)
EDITORIAL_REVIEW_TOKEN=
